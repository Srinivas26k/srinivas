---
import Analytics from '../components/Analytics.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/logo.png" />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

  <!-- SEO -->
  <title>Srinivas Nampalli — AI Systems Developer</title>
  <meta name="title" content="Srinivas Nampalli — AI Systems Developer" />
  <meta name="description" content="AI Systems Developer, Quantum Computing Researcher, and Open Source Contributor. IIT Madras. Winner — Qiskit Fall Fest 2025." />
  <meta name="keywords" content="Srinivas Nampalli, AI Systems, Quantum Computing, Qiskit, IIT Madras, Multi-Agent Systems, LangChain, Google ADK" />

  <!-- OG -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content="Srinivas Nampalli — AI Systems Developer" />
  <meta property="og:description" content="AI Systems Developer, Quantum Computing Researcher, and Open Source Contributor." />

  <!-- JSON-LD Person Schema -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Srinivas Nampalli",
      "url": "https://srinivas.ai",
      "sameAs": [
        "https://github.com/Srinivas26k",
        "https://in.linkedin.com/in/srinivas-nampalli"
      ],
      "jobTitle": "AI Systems Developer",
      "alumniOf": "Indian Institute of Technology Madras"
    }
  </script>

  <Analytics />
</head>
<body>
  <!-- Scroll Progress — Signal Lime per design.md -->
  <div id="scroll-progress" aria-hidden="true"></div>

  <slot />

  <!-- Motion Engine: Lenis + GSAP -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // ── Lenis Smooth Scroll ──────────────────────────────────────
    const lenis = new Lenis({
      lerp: 0.075,
      smoothWheel: true,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);

    // ── Scroll Progress Bar (Signal Lime) ────────────────────────
    const progressBar = document.getElementById('scroll-progress');
    if (progressBar) {
      lenis.on('scroll', ({ progress }: { progress: number }) => {
        progressBar.style.width = `${progress * 100}%`;
      });
    }

    // ── Section Reveals — design.md: opacity 0 + translateY(32px) → 1 + 0
    //    Triggered at threshold: 0.15, --dur-slow (0.7s), --ease-out
    const revealEls = document.querySelectorAll('.reveal');
    revealEls.forEach((el) => {
      gsap.fromTo(el,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: 'power3.out', // approximates cubic-bezier(0.16, 1, 0.3, 1)
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',   // threshold ~0.15 from bottom
            toggleActions: 'play none none none',
          }
        }
      );
      (el as HTMLElement).style.opacity = '0';
    });

    // ── Parallax sections ─────────────────────────────────────────
    document.querySelectorAll('.parallax-slow').forEach((el) => {
      gsap.to(el, {
        yPercent: -10,
        ease: 'none',
        scrollTrigger: {
          trigger: el,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        }
      });
    });

    document.querySelectorAll('.parallax-fast').forEach((el) => {
      gsap.to(el, {
        yPercent: -18,
        ease: 'none',
        scrollTrigger: {
          trigger: el,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        }
      });
    });

    // ── Hero Entry Sequence — design.md animation catalogue ──────
    // Fires on page load, sequenced per spec:
    // t=0ms label, t=100ms line1, t=250ms line2, t=600ms sub, t=750ms CTAs
    const heroTl = gsap.timeline({ delay: 0.05 });

    const heroLabel   = document.querySelector('[data-hero="label"]');
    const heroName    = document.querySelector('[data-hero="name"]');
    const heroRole    = document.querySelector('[data-hero="role"]');
    const heroMeta    = document.querySelector('[data-hero="meta"]');
    const heroActions = document.querySelector('[data-hero="actions"]');
    const headerEl    = document.querySelector('header');

    // Label fades in from translateY(8px)
    if (heroLabel)   heroTl.fromTo(heroLabel,   { opacity: 0, y: 8  }, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, 0);
    // Header fades in simultaneously
    if (headerEl)    heroTl.fromTo(headerEl,    { opacity: 0 },        { opacity: 1, duration: 0.4, ease: 'none' }, 0.0);
    // Display headline — clipPath reveal per design.md
    if (heroName)    heroTl.fromTo(heroName,    { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.75, ease: 'power4.out' }, 0.1);
    // Role / sub-copy
    if (heroRole)    heroTl.fromTo(heroRole,    { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.35);
    // Meta strip
    if (heroMeta)    heroTl.fromTo(heroMeta,    { opacity: 0 },        { opacity: 1, duration: 0.5, ease: 'none' }, 0.5);
    // CTA buttons — stagger 80ms
    if (heroActions) heroTl.fromTo(heroActions, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, 0.6);

    // ── Hero parallax on scroll ─────────────────────────────────
    const heroSection = document.querySelector('#home');
    if (heroSection) {
      gsap.to('[data-hero="name"]', {
        yPercent: -10,
        opacity: 0.85,
        ease: 'none',
        scrollTrigger: {
          trigger: heroSection,
          start: 'top top',
          end: 'bottom top',
          scrub: 1,
        }
      });
    }

    // ── Project entries stagger ──────────────────────────────────
    gsap.fromTo('.project-entry',
      { opacity: 0, y: 28 },
      {
        opacity: 1,
        y: 0,
        duration: 0.85,
        stagger: 0.08,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#work',
          start: 'top 72%',
          toggleActions: 'play none none none',
        }
      }
    );

    // ── Count-up numbers (metrics) ───────────────────────────────
    document.querySelectorAll('[data-countup]').forEach((el) => {
      const target = parseInt((el as HTMLElement).dataset.countup || '0', 10);
      const suffix = (el as HTMLElement).dataset.suffix || '';
      ScrollTrigger.create({
        trigger: el,
        start: 'top 80%',
        onEnter: () => {
          let start = 0;
          const step = target / 60;
          const interval = setInterval(() => {
            start = Math.min(start + step, target);
            el.textContent = Math.round(start) + suffix;
            if (start >= target) clearInterval(interval);
          }, 1000 / 60);
        }
      });
    });

    // ── Header scroll behaviour — border appears after 60px ─────
    if (headerEl) {
      let lastScroll = 0;
      lenis.on('scroll', ({ scroll }: { scroll: number }) => {
        // Add scrolled class for border-bottom
        if (scroll > 60) {
          (headerEl as HTMLElement).classList.add('scrolled');
        } else {
          (headerEl as HTMLElement).classList.remove('scrolled');
        }
        // Hide/show on scroll direction
        const delta = scroll - lastScroll;
        if (scroll > 80) {
          if (delta > 0) {
            (headerEl as HTMLElement).style.transform = 'translateY(-100%)';
          } else {
            (headerEl as HTMLElement).style.transform = 'translateY(0)';
          }
        } else {
          (headerEl as HTMLElement).style.transform = 'translateY(0)';
        }
        lastScroll = scroll;
      });
    }

    // ── Marquee ticker — start when in view ─────────────────────
    document.querySelectorAll('.ticker-band').forEach((band) => {
      const inner = band.querySelector('.ticker-inner') as HTMLElement | null;
      if (!inner) return;
      inner.style.animationPlayState = 'paused';
      ScrollTrigger.create({
        trigger: band,
        start: 'top 90%',
        onEnter: () => {
          inner.style.animationPlayState = 'running';
        }
      });
    });
  </script>
</body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  header {
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  /* Border-bottom fades in on scroll — per design.md nav spec */
  header.scrolled::after {
    border-bottom-color: rgba(240, 238, 233, 0.06) !important;
    background: rgba(10, 10, 10, 0.95) !important;
  }
</style>
