---
---
<section id="home" aria-label="Hero — Srinivas Nampalli">

  <!-- Section label -->
  <p class="t-label hero-label" data-hero="label" style="opacity:0">
    Srinivas Nampalli · IIT Madras · AI + Quantum
  </p>

  <!-- Display headline — overflow clipped at container edge per design.md -->
  <div class="hero-headline-wrap">
    <h1 class="t-display-1 hero-name" data-hero="name" style="opacity:0">
      Systems<br/>Engineer.
    </h1>
  </div>

  <!-- Sub-copy — --body-large, weight 300, max 440px -->
  <p class="t-body-lg hero-role" data-hero="role" style="opacity:0">
    Designing intelligent systems at the intersection of<br class="br-md"/>
    AI, Quantum Computing, and Mechanical Engineering.
  </p>

  <!-- Metadata row -->
  <div class="hero-meta" data-hero="meta" style="opacity:0">
    <span class="hero-meta-item">
      <span class="meta-dot" aria-hidden="true"></span>
      <span class="t-mono">Qiskit Fall Fest 2025 Winner</span>
    </span>
    <span class="meta-sep t-mono" aria-hidden="true">·</span>
    <span class="t-mono hero-meta-item">5+ Industry Internships</span>
    <span class="meta-sep t-mono" aria-hidden="true">·</span>
    <span class="t-mono hero-meta-item">1k+ HuggingFace Downloads</span>
  </div>

  <!-- CTAs — Primary Lime + Ghost per design.md -->
  <div class="hero-actions" data-hero="actions" style="opacity:0">
    <a href="#work" class="btn-primary" id="hero-cta-primary">
      View Work ↓
    </a>
    <a
      href="https://in.linkedin.com/in/srinivas-nampalli"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost"
      id="hero-cta-secondary"
    >
      LinkedIn ↗
    </a>
  </div>

  <!-- Scroll indicator — Signal Lime bouncing arrow per design.md -->
  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-arrow">↓</span>
  </div>

</section>

<style>
  #home {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px;
    padding-bottom: var(--space-10);
    padding-inline: var(--col-pad);
    max-width: var(--max-width);
    margin-inline: auto;
    overflow: hidden;
  }

  /* Hero label */
  .hero-label {
    margin-bottom: var(--space-4);
  }

  /* Display headline wrapper — clip overflow per design.md */
  .hero-headline-wrap {
    overflow: hidden;
    /* allow text to intentionally exceed container */
  }

  .hero-name {
    margin-bottom: var(--space-5);
    /* Display-1 at 12vw overflows — line-height 0.92 */
  }

  /* Sub-copy */
  .hero-role {
    max-width: 480px;
    color: var(--c-off-white);
    margin-bottom: var(--space-5);
  }

  .br-md { display: none; }
  @media (min-width: 768px) { .br-md { display: block; } }

  /* Meta strip */
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--c-stone);
  }

  .meta-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--c-lime);
    flex-shrink: 0;
  }

  .meta-sep {
    color: var(--c-stone);
    opacity: 0.5;
  }

  /* Actions row */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  /* Scroll indicator — Signal Lime slow bounce */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: var(--col-pad);
  }

  .scroll-arrow {
    display: block;
    font-size: 20px;
    color: var(--c-lime);
    animation: scroll-bounce 1.8s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ── Mobile ──────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    #home {
      padding-top: 100px;
    }

    .hero-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .meta-sep { display: none; }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }

    .btn-primary,
    .btn-ghost {
      width: 100%;
      justify-content: center;
    }
  }
</style>
