---
---
<section id="home" aria-label="Hero — Identity">
  <div class="container hero-layout">

    <!-- Top label -->
    <p class="t-label hero-label" data-hero="label" style="opacity:0">
      Srinivas Nampalli · IIT Madras · AI + Quantum
    </p>

    <!-- Primary Name -->
    <h1 class="t-hero hero-name" data-hero="name" style="opacity:0">
      Systems<br/>Engineer.
    </h1>

    <!-- Role statement -->
    <p class="hero-role" data-hero="role" style="opacity:0">
      Designing intelligent systems at the intersection of<br class="br-md"/>
      AI, Quantum Computing, and Mechanical Engineering.
    </p>

    <!-- Metadata row -->
    <div class="hero-meta" data-hero="meta" style="opacity:0">
      <span class="t-mono hero-meta-item">
        <span class="meta-dot"></span>
        Qiskit Fall Fest 2025 Winner
      </span>
      <span class="t-mono hero-meta-sep" aria-hidden="true">·</span>
      <span class="t-mono hero-meta-item">
        5+ Industry Internships
      </span>
      <span class="t-mono hero-meta-sep" aria-hidden="true">·</span>
      <span class="t-mono hero-meta-item">
        1k+ HuggingFace Downloads
      </span>
    </div>

    <!-- Actions -->
    <div class="hero-actions" data-hero="actions" style="opacity:0">
      <a href="#work" class="btn-primary-text">
        View Work <span aria-hidden="true">↓</span>
      </a>
      <a
        href="https://in.linkedin.com/in/srinivas-nampalli"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary-text"
      >
        LinkedIn ↗
      </a>
    </div>
  </div>

  <!-- Decorative vertical rule -->
  <div class="hero-rule" aria-hidden="true"></div>
</section>

<style>
  #home {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 120px;
    padding-bottom: var(--sp-20);
    overflow: hidden;
  }

  .hero-layout {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    max-width: 900px;
  }

  .hero-label {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
  }

  .hero-name {
    /* Override line-height for dramatic effect */
    line-height: 0.93;
    margin-top: var(--sp-2);
  }

  .hero-role {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    color: var(--c-text-secondary);
    max-width: 560px;
    margin-top: var(--sp-1);
  }

  .br-md {
    display: none;
  }

  @media (min-width: 768px) {
    .br-md { display: block; }
  }

  /* Meta row */
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-1);
  }

  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .meta-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--c-text-faint);
    flex-shrink: 0;
  }

  .hero-meta-sep {
    color: var(--c-text-faint);
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-top: var(--sp-3);
  }

  .btn-primary-text {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--c-text-primary);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .btn-primary-text:hover {
    color: var(--c-white);
  }

  .btn-secondary-text {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: var(--ls-mono);
    color: var(--c-text-mono);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .btn-secondary-text:hover {
    color: var(--c-text-secondary);
  }

  /* Vertical decorative line */
  .hero-rule {
    position: absolute;
    right: var(--col-pad);
    top: 15%;
    bottom: 15%;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--c-border) 20%,
      var(--c-border) 80%,
      transparent 100%
    );
    opacity: 0.5;
    display: none;
  }

  @media (min-width: 1024px) {
    .hero-rule { display: block; }
  }

  @media (max-width: 600px) {
    .hero-meta {
      flex-direction: column;
      align-items: flex-start;
    }
    .hero-meta-sep { display: none; }
  }
</style>
