---
---
<section id="hero-voir" aria-label="Hero">
  <!-- Parallax Background Image -->
  <div class="hero-bg-wrapper">
    <div class="hero-bg-image" style="background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop');"></div>
  </div>

  <!-- Progressive Blur Overlay (8 layers) -->
  <div class="progressive-blur">
    <div class="blur-layer layer-1"></div>
    <div class="blur-layer layer-2"></div>
    <div class="blur-layer layer-3"></div>
    <div class="blur-layer layer-4"></div>
    <div class="blur-layer layer-5"></div>
    <div class="blur-layer layer-6"></div>
    <div class="blur-layer layer-7"></div>
    <div class="blur-layer layer-8"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-center">
      <!-- Large Serif Name -->
      <h1 class="hero-title t-display-1" aria-label="Srinivas Nampalli">
        <span class="word">
          <span class="char">S</span><span class="char">r</span><span class="char">i</span><span class="char">n</span><span class="char">i</span><span class="char">v</span><span class="char">a</span><span class="char">s</span>
        </span>
        <br />
        <span class="word">
          <span class="char">N</span><span class="char">a</span><span class="char">m</span><span class="char">p</span><span class="char">a</span><span class="char">l</span><span class="char">l</span><span class="char">i</span>
        </span>
      </h1>
      
      <!-- Sub-label -->
      <p class="hero-sublabel t-body">
        Brand & Design Studio — Hyderabad / Worldwide
      </p>
    </div>

    <!-- Bottom elements -->
    <div class="hero-bottom">
      <div class="hero-thumbnails">
        <div class="thumb" style="background-image: url('https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=600&auto=format&fit=crop');"></div>
        <div class="thumb" style="background-image: url('https://images.unsplash.com/photo-1550684848-fac1c5b4e853?q=80&w=600&auto=format&fit=crop');"></div>
        <div class="thumb" style="background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=600&auto=format&fit=crop');"></div>
        <div class="thumb" style="background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=600&auto=format&fit=crop');"></div>
      </div>
      
      <div class="hero-scroll">
        <div class="scroll-line"></div>
        <span class="t-label">SCROLL</span>
      </div>
    </div>
  </div>
</section>

<style>
  #hero-voir {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background: var(--c-ink);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 1;
  }

  .hero-bg-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transform: scale(1.15); /* Start scale for parallax spring */
    will-change: transform;
    opacity: 0.5; /* Dark overlay */
    background-color: var(--c-ink);
  }

  /* Progressive Blur */
  .progressive-blur {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40vh;
    z-index: 2;
    pointer-events: none;
  }

  .blur-layer {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* 8 layers of blur matching VOIR's gradient mask technique */
  /* Fallback to simple gradient if masks aren't supported, but webkit mask is widely supported */
  .layer-1 { backdrop-filter: blur(1px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 12.5%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 12.5%); }
  .layer-2 { backdrop-filter: blur(2px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 12.5%, rgba(0,0,0,0) 25%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 12.5%, rgba(0,0,0,0) 25%); }
  .layer-3 { backdrop-filter: blur(3px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 25%, rgba(0,0,0,0) 37.5%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 25%, rgba(0,0,0,0) 37.5%); }
  .layer-4 { backdrop-filter: blur(4px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 37.5%, rgba(0,0,0,0) 50%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 37.5%, rgba(0,0,0,0) 50%); }
  .layer-5 { backdrop-filter: blur(5px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 62.5%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 62.5%); }
  .layer-6 { backdrop-filter: blur(6px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 62.5%, rgba(0,0,0,0) 75%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 62.5%, rgba(0,0,0,0) 75%); }
  .layer-7 { backdrop-filter: blur(8px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 87.5%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 87.5%); }
  .layer-8 { backdrop-filter: blur(10px); -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,1) 87.5%, rgba(0,0,0,0) 100%); mask-image: linear-gradient(to top, rgba(0,0,0,1) 87.5%, rgba(0,0,0,0) 100%); }

  .hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: var(--space-8);
    padding-bottom: var(--space-6);
  }

  .hero-center {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    margin-top: 5vh;
  }

  .hero-title {
    margin-bottom: var(--space-4);
  }

  .hero-title .word {
    display: inline-block;
    overflow: hidden; 
  }

  .hero-title .char {
    display: inline-block;
    opacity: 0.001;
    transform: translateY(10px);
    will-change: transform, opacity;
  }

  .hero-sublabel {
    max-width: 400px;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(10px);
    color: var(--c-off-white);
  }

  /* Bottom Section */
  .hero-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
  }

  .hero-thumbnails {
    display: flex;
    gap: var(--space-2);
  }

  .thumb {
    width: 60px;
    height: 80px;
    background: var(--c-dust);
    background-size: cover;
    background-position: center;
    border-radius: 2px;
    cursor: crosshair;
    transition: transform var(--dur-base) var(--ease-out);
    will-change: transform;
  }

  .thumb:hover {
    transform: translateY(-8px);
  }

  .hero-scroll {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .scroll-line {
    width: 60px;
    height: 1px;
    background: var(--c-line-strong);
  }

  @media (max-width: 768px) {
    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-5);
    }
    
    .hero-thumbnails {
      order: 2;
    }
    
    .hero-scroll {
      order: 1;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  
  document.addEventListener("DOMContentLoaded", () => {
    const tl = gsap.timeline();

    // 1. Background parallax spring
    tl.to(".hero-bg-image", {
      scale: 1,
      duration: 2.4,
      ease: "power4.out"
    }, 0);

    // 2. Letter by letter reveal
    tl.to(".hero-title .char", {
      opacity: 1,
      y: 0,
      duration: 1.2,
      stagger: 0.04,
      ease: "power3.out"
    }, 0.2);

    // 3. Sublabel fade up
    tl.to(".hero-sublabel", {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: "power2.out"
    }, 1.0);
  });
</script>
