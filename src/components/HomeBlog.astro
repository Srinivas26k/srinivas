---
---
<!-- SECTION: Blog / Journal -->
<section class="blog-section" aria-label="Journal">
  <div class="watermark-wrap">
    <svg class="fit-text watermark-svg" viewBox="0 0 1000 160" preserveAspectRatio="xMidYMid meet">
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" class="watermark-text">THE JOURNAL</text>
    </svg>
  </div>

  <div class="container">
    <div class="blog-grid">

      <!-- Post 1 — PLACEHOLDER -->
      <a href="/blog/first-post" class="blog-card">
        <div class="blog-img-wrap">
          <div class="cover-wipe-b"></div>
          <img src="/images/blog_1.jpg" alt="Why Editorial Design Wins" class="blog-img" />
        </div>
        <div class="blog-meta">
          <span class="t-label blog-category">Design Thinking</span>
          <h3 class="t-h2 blog-title">Why Editorial Design Wins in the Age of AI</h3>
          <span class="t-mono blog-date">Apr 10, 2026</span>
        </div>
      </a>

      <!-- Post 2 — PLACEHOLDER -->
      <a href="/blog/gsap-scroll-patterns" class="blog-card">
        <div class="blog-img-wrap">
          <div class="cover-wipe-b"></div>
          <img src="/images/blog_2.jpg" alt="GSAP ScrollTrigger Patterns" class="blog-img" />
        </div>
        <div class="blog-meta">
          <span class="t-label blog-category">Motion Design</span>
          <h3 class="t-h2 blog-title">GSAP ScrollTrigger Patterns That Actually Work</h3>
          <span class="t-mono blog-date">Mar 28, 2026</span>
        </div>
      </a>

      <!-- Post 3 — PLACEHOLDER -->
      <a href="/blog/designing-ai-interfaces" class="blog-card">
        <div class="blog-img-wrap">
          <div class="cover-wipe-b"></div>
          <img src="/images/blog_3.jpg" alt="Designing AI Interfaces" class="blog-img" />
        </div>
        <div class="blog-meta">
          <span class="t-label blog-category">AI Design</span>
          <h3 class="t-h2 blog-title">Designing Interfaces for Probabilistic Systems</h3>
          <span class="t-mono blog-date">Mar 15, 2026</span>
        </div>
      </a>

    </div>

    <div class="blog-footer">
      <a href="/blog" class="btn-text">Read More (03) →</a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    background: var(--c-ink);
    padding-block: var(--space-10);
    overflow: hidden;
  }

  .watermark-wrap {
    width: 100%;
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .watermark-svg {
    width: 110%;
    margin-left: -5%;
    height: auto;
    fill: var(--c-stone);
    opacity: 0.06;
  }

  .watermark-text {
    font-family: var(--font-display);
    font-size: 180px;
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .blog-card {
    display: block;
    text-decoration: none;
    opacity: 0;
    transform: translateY(30px);
  }

  .blog-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/2;
    margin-bottom: var(--space-3);
    cursor: crosshair;
  }

  .cover-wipe-b {
    position: absolute;
    inset: 0;
    background: var(--c-ink);
    z-index: 2;
    transform-origin: top;
  }

  .blog-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .blog-card:hover .blog-img {
    transform: scale(1.04);
  }

  .blog-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .blog-category {
    color: var(--c-taupe);
  }

  .blog-title {
    color: var(--c-off-white);
    font-size: clamp(18px, 2vw, 24px);
  }

  .blog-date {
    color: var(--c-stone);
  }

  .blog-footer {
    text-align: right;
    margin-top: var(--space-4);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.to(".blog-card", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.08,
      ease: "power2.out",
      scrollTrigger: { trigger: ".blog-grid", start: "top 80%" }
    });

    gsap.utils.toArray(".blog-img-wrap").forEach(wrap => {
      const wipe = (wrap as HTMLElement).querySelector(".cover-wipe-b");
      gsap.to(wipe, {
        scaleY: 0,
        duration: 1.2,
        ease: "expo.inOut",
        scrollTrigger: { trigger: wrap as Element, start: "top 85%" }
      });
    });
  });
</script>
