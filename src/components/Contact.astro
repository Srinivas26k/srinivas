---
<!-- Large Surface CTA band — design.md §4 "Large Surface CTA" -->
<div class="cta-band">
  <div class="container cta-inner">
    <span class="section-marker cta-label reveal">Ready to connect?</span>
    <h2 class="t-display-2 cta-headline reveal">
      Let's build<br/>something.
    </h2>
    <p class="t-small cta-sub reveal">
      Open to research collaborations, freelance consulting, and<br/>
      senior engineering roles in AI systems or quantum computing.
    </p>
    <a href="mailto:srinivasvarma764@gmail.com" class="btn-primary cta-btn reveal" id="contact-primary-cta">
      Start a Conversation →
    </a>
    <p class="t-small cta-email reveal">
      Or email directly: <a href="mailto:srinivasvarma764@gmail.com">srinivasvarma764@gmail.com</a>
    </p>
  </div>
</div>

<section id="contact" aria-label="Contact">
  <div class="container">

    <!-- Section header -->
    <div class="section-header reveal">
      <span class="section-marker">Contact</span>
      <div class="divider" style="margin-top: var(--space-3)"></div>
    </div>

    <div class="contact-layout">

      <!-- Left: Headline -->
      <div class="contact-statement reveal">
        <h2 class="t-h1 contact-title" style="letter-spacing: -0.03em; line-height: 1.1;">
          Let's work<br/>together.
        </h2>
        <p class="t-body contact-desc">
          Reach out through any channel below.
          I respond within 24 hours.
        </p>
        <!-- Available status dot -->
        <div class="status-row">
          <span class="status-dot" aria-label="Currently available for work"></span>
          <span class="t-mono status-text">Available for work</span>
        </div>
      </div>

      <!-- Right: Contact links — Ash card per design.md -->
      <div class="contact-links surface-card reveal">

        <div class="contact-item">
          <span class="t-label contact-key">Email</span>
          <a href="mailto:srinivasvarma764@gmail.com" class="contact-val t-mono">
            srinivasvarma764@gmail.com <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-key">LinkedIn</span>
          <a
            href="https://in.linkedin.com/in/srinivas-nampalli"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-val t-mono"
          >
            /in/srinivas-nampalli <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-key">GitHub</span>
          <a
            href="https://github.com/Srinivas26k"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-val t-mono"
          >
            /Srinivas26k <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-key">HuggingFace</span>
          <a
            href="https://huggingface.co/Srinivasmec26"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-val t-mono"
          >
            /Srinivasmec26 <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-key">Medium</span>
          <a
            href="https://medium.com/@srinivasvarma764"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-val t-mono"
          >
            @srinivasvarma764 <span aria-hidden="true">↗</span>
          </a>
        </div>

      </div>

    </div>

    <!-- Site footer — design.md §9.1 Section 10 -->
    <footer class="site-footer reveal">
      <span class="t-mono footer-copy">© 2025 Srinivas Nampalli</span>
      <span class="t-mono footer-copy">Hyderabad, India</span>
      <span class="t-mono footer-copy">Built with intention.</span>
    </footer>

  </div>
</section>

<style>
  /* ── Large Surface CTA Band — Ash background ─────────────────── */
  .cta-band {
    background: var(--c-ash);
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
    padding-block: var(--space-10);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
  }

  .cta-label {
    text-align: center;
  }

  .cta-headline {
    max-width: 800px;
    text-align: center;
  }

  .cta-sub {
    max-width: 400px;
    text-align: center;
    color: var(--c-stone);
    line-height: 1.7;
  }

  .cta-btn {
    margin-top: var(--space-2);
  }

  .cta-email {
    color: var(--c-stone);
    text-align: center;
  }

  .cta-email a {
    color: var(--c-off-white);
    transition: color var(--dur-base) var(--ease-out);
  }

  .cta-email a:hover {
    color: var(--c-lime);
  }

  /* ── Section Header ─────────────────────────────────────────── */
  .section-header {
    margin-bottom: var(--space-8);
  }

  /* ── Contact Layout ──────────────────────────────────────────── */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(40px, 8vw, 120px);
    align-items: start;
  }

  @media (max-width: 767px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* Left statement */
  .contact-title {
    color: var(--c-off-white);
    margin-bottom: var(--space-5);
  }

  .contact-desc {
    color: var(--c-stone);
    max-width: 300px;
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  /* Available status */
  .status-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--c-success);
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.5);
    flex-shrink: 0;
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  .status-text {
    color: var(--c-off-white);
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 0.65; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  /* ── Contact Links Card ──────────────────────────────────────── */
  .contact-links {
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-4);
  }

  .contact-item {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-4);
    border-radius: var(--radius-card);
    transition: background-color var(--dur-base) var(--ease-in-out);
    padding-inline: var(--space-2);
    margin-inline: calc(var(--space-2) * -1);
  }

  .contact-item:hover {
    background-color: rgba(240, 238, 233, 0.03);
  }

  .contact-key {
    color: var(--c-stone);
    flex-shrink: 0;
  }

  .contact-val {
    color: var(--c-off-white);
    font-size: var(--fs-mono);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out), transform var(--dur-base) var(--ease-out);
  }

  .contact-val:hover {
    color: var(--c-lime);
    transform: translateX(3px);
  }

  /* ── Footer ──────────────────────────────────────────────────── */
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-10);
    padding-top: var(--space-5);
    border-top: 1px solid var(--c-line);
  }

  .footer-copy {
    color: var(--c-stone);
    font-size: 11px;
    letter-spacing: 0.06em;
  }

  @media (max-width: 480px) {
    .contact-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .site-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>