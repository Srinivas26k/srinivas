---
<section id="contact" aria-label="Contact">
  <div class="container">

    <!-- Section header -->
    <div class="section-header reveal">
      <span class="t-label">Contact</span>
      <div class="divider" style="margin-top: var(--sp-3)"></div>
    </div>

    <div class="contact-layout">

      <!-- Left: Statement -->
      <div class="contact-statement reveal">
        <h2 class="t-h1" style="letter-spacing: -0.03em; line-height: 1.1;">
          Let's work<br/>together.
        </h2>
        <p class="t-small" style="margin-top: var(--sp-5); max-width: 320px; line-height: 1.7;">
          Open to research collaborations, freelance consulting, and
          senior engineering roles in AI systems or quantum computing.
        </p>
      </div>

      <!-- Right: Contact links -->
      <div class="contact-links reveal surface-card">
        <div class="contact-item">
          <span class="t-label contact-label">Email</span>
          <a href="mailto:srinivasvarma764@gmail.com" class="contact-value t-mono">
            srinivasvarma764@gmail.com <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-label">LinkedIn</span>
          <a
            href="https://in.linkedin.com/in/srinivas-nampalli"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value t-mono"
          >
            /in/srinivas-nampalli <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-label">GitHub</span>
          <a
            href="https://github.com/Srinivas26k"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value t-mono"
          >
            /Srinivas26k <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-label">HuggingFace</span>
          <a
            href="https://huggingface.co/Srinivasmec26"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value t-mono"
          >
            /Srinivasmec26 <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item">
          <span class="t-label contact-label">Medium</span>
          <a
            href="https://medium.com/@srinivasvarma764"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-value t-mono"
          >
            @srinivasvarma764 <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="divider"></div>

        <div class="contact-item contact-status">
          <span class="t-label contact-label">Status</span>
          <span class="status-indicator t-mono">
            <span class="status-dot" aria-hidden="true"></span>
            Available for work
          </span>
        </div>
      </div>

    </div>

    <!-- Footer line -->
    <div class="site-footer reveal">
      <span class="t-mono">© 2025 Srinivas Nampalli</span>
      <span class="t-mono">Hyderabad, India</span>
    </div>

  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--sp-8);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(40px, 8vw, 120px);
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--sp-10);
    }
  }

  /* Statement */
  .contact-statement {}

  /* Links */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 10px 14px;
  }

  .contact-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-4);
    align-items: center;
    padding-block: var(--sp-3);
    border-radius: var(--radius-sm);
    transition: background-color var(--dur-base) var(--ease-in-out);
  }

  .contact-item:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  .contact-label {
    color: var(--c-text-faint);
    flex-shrink: 0;
  }

  .contact-value {
    font-size: var(--fs-mono);
    color: var(--c-text-secondary);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out), transform var(--dur-base) var(--ease-out-expo);
    letter-spacing: var(--ls-mono);
  }

  .contact-value:hover {
    color: var(--c-text-primary);
    transform: translateX(2px);
  }

  /* Status */
  .status-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--c-text-secondary);
    font-size: var(--fs-mono);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #4ade80; /* green */
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.5);
    flex-shrink: 0;
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 0.65; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  /* Footer */
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--sp-16);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--c-border);
  }

  @media (max-width: 480px) {
    .contact-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>