---
import projects from "../data/projects.json";

type Link = { type: string; label: string; url: string };
type Project = {
  id: string;
  title: string;
  description: string;
  image: string;
  tags: string[];
  links?: Link[];
  year?: number;
  featured?: boolean;
  period?: string;
};

const allProjects = (projects as Project[]);
// Featured first, then by year descending
const sorted = [...allProjects].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return (b.year ?? 0) - (a.year ?? 0);
});

// Separate featured (primary) from the rest (archive)
const primary = sorted.filter(p => p.featured);
const archive = sorted.filter(p => !p.featured);

// Architecture logic: define what each featured project "did" as a system
const architectureMap: Record<string, { objective: string; architecture: string; outcome: string }> = {
  "market-trend-agents": {
    objective: "Real-time market intelligence via coordinated agent networks.",
    architecture: "Retriever → Planner → Reasoning agents with shared memory (LangGraph + Google ADK).",
    outcome: "Adaptive trend forecasts from live market data streams."
  },
  "quantum-bb84-sim": {
    objective: "Implement and validate a production-grade quantum key distribution system.",
    architecture: "BB84 protocol → Qiskit simulation → Eavesdrop detection via no-cloning theorem.",
    outcome: "25.1% key generation efficiency. Winner — Qiskit Fall Fest 2025."
  },
  "llm-dataset-suite": {
    objective: "Build scalable fine-tuning corpora for domain-specific LLMs.",
    architecture: "Web scraping → Structured metadata → Prompt-response pairs → Augmentation pipeline.",
    outcome: "4 datasets published. 1,000+ downloads on HuggingFace."
  },
  "annam-ai-rag-scraper": {
    objective: "Automated data pipeline for Retrieval-Augmented Generation systems.",
    architecture: "Recursive crawler → Multi-format extraction → Structured RAG metadata export.",
    outcome: "Base64 ZIP export with PDF text extraction for LLM training pipelines."
  },
  "ayurleaf-healthcare": {
    objective: "Open-source AI health recommendation platform.",
    architecture: "Full-stack bug fixes → UI modules → AI health logic optimization.",
    outcome: "GSSoC 2025 contributions improving analytics dashboard performance."
  },
  "pustak-ghar": {
    objective: "Accessible study resource platform for university students.",
    architecture: "Responsive UI → Branch-wise content filters → Optimized navigation.",
    outcome: "Reduced friction for PYQ access across engineering branches."
  },
};
---

<section id="work" aria-label="Selected Work">
  <div class="container">

    <!-- Section header -->
    <div class="section-header reveal">
      <span class="t-label">Selected Work</span>
      <div class="divider" style="margin-top: var(--sp-3)"></div>
    </div>

    <!-- Primary Projects -->
    <div class="projects-list">
      {primary.map((p, i) => {
        const arch = architectureMap[p.id];
        const year = p.period ?? p.year ?? '';
        const primaryLink = p.links?.[0];
        return (
          <article class="project-entry reveal" data-index={i}>
            <div class="project-entry-inner">

              <!-- Left: Index + year -->
              <div class="project-meta-left">
                <span class="t-mono project-index">{String(i + 1).padStart(2, '0')}</span>
                <span class="t-mono project-year">{year}</span>
              </div>

              <!-- Center: Content -->
              <div class="project-content">
                <div class="project-top-row">
                  <h3 class="project-title">{p.title}</h3>
                  {primaryLink && (
                    <a
                      href={primaryLink.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link t-mono"
                      aria-label={`Open ${p.title}`}
                    >
                      ↗
                    </a>
                  )}
                </div>

                <p class="project-description t-small">{p.description}</p>

                <!-- Architecture Manifest (system thinking layer) -->
                {arch && (
                  <div class="arch-manifest">
                    <div class="arch-row">
                      <span class="arch-key t-label">Objective</span>
                      <span class="arch-val t-mono">{arch.objective}</span>
                    </div>
                    <div class="arch-row">
                      <span class="arch-key t-label">Architecture</span>
                      <span class="arch-val t-mono">{arch.architecture}</span>
                    </div>
                    <div class="arch-row">
                      <span class="arch-key t-label">Outcome</span>
                      <span class="arch-val t-mono">{arch.outcome}</span>
                    </div>
                  </div>
                )}

                <!-- Tags -->
                <div class="project-tags">
                  {p.tags.map(tag => (
                    <span class="tag t-label">{tag}</span>
                  ))}
                </div>

                <!-- All Links -->
                {p.links && p.links.length > 0 && (
                  <div class="project-links">
                    {p.links.map(link => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="t-mono project-link-item"
                      >
                        {link.label} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
            <div class="divider" style="margin-top: var(--sp-6)"></div>
          </article>
        );
      })}
    </div>

    <!-- Archive (non-featured) -->
    {archive.length > 0 && (
      <div class="archive-section reveal">
        <div class="archive-header">
          <span class="t-label">Archive</span>
        </div>
        <div class="archive-grid">
          {archive.map((p) => {
            const primaryLink = p.links?.[0];
            return (
              <div class="archive-item">
                <div class="archive-top">
                  <span class="t-mono archive-year">{p.year}</span>
                  {primaryLink && (
                    <a
                      href={primaryLink.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="archive-link t-mono"
                    >↗</a>
                  )}
                </div>
                <h4 class="archive-title">{p.title}</h4>
                <div class="project-tags" style="margin-top: var(--sp-2)">
                  {p.tags.slice(0, 3).map(tag => (
                    <span class="tag t-label">{tag}</span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  /* Section header */
  .section-header {
    margin-bottom: var(--sp-8);
  }

  /* Project entry list */
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-entry {
    padding-top: var(--sp-4);
  }

  .project-entry-inner {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-6);
    align-items: start;
    padding: var(--sp-4);
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(20, 20, 20, 0.35), rgba(14, 14, 14, 0.35));
    transition:
      transform var(--dur-base) var(--ease-out-expo),
      border-color var(--dur-base) var(--ease-in-out),
      background var(--dur-base) var(--ease-in-out);
  }

  .project-entry:hover .project-entry-inner {
    transform: translateY(-4px);
    border-color: var(--c-border);
    background: linear-gradient(180deg, rgba(24, 24, 24, 0.68), rgba(16, 16, 16, 0.68));
  }

  /* Left meta column */
  .project-meta-left {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding-top: 4px;
  }

  .project-index {
    font-size: 0.7rem;
    color: var(--c-text-faint);
  }

  .project-year {
    font-size: 0.7rem;
    color: var(--c-text-faint);
  }

  /* Content area */
  .project-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: clamp(1.05rem, 2vw, 1.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--c-text-primary);
    max-width: 600px;
  }

  .project-link {
    flex-shrink: 0;
    color: var(--c-text-faint);
    font-size: 1rem;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
    margin-top: 2px;
  }

  .project-link:hover {
    color: var(--c-text-primary);
  }

  .project-description {
    max-width: 640px;
    margin-bottom: var(--sp-5);
    line-height: 1.75;
    color: color-mix(in srgb, var(--c-text-secondary) 92%, white);
  }

  /* Architecture Manifest */
  .arch-manifest {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-3);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, rgba(24, 24, 24, 0.85), rgba(18, 18, 18, 0.85));
    margin-bottom: var(--sp-4);
    max-width: 640px;
  }

  .arch-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-3);
    align-items: baseline;
  }

  .arch-key {
    color: var(--c-text-faint);
    flex-shrink: 0;
  }

  .arch-val {
    color: var(--c-text-secondary);
    line-height: 1.5;
  }

  /* Tags */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    margin-bottom: var(--sp-3);
  }

  .tag {
    padding: 3px 8px;
    border: 1px solid var(--c-border);
    border-radius: 999px;
    color: var(--c-text-mono);
    font-size: 0.6rem;
  }

  /* Project links */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .project-link-item {
    color: var(--c-text-mono);
    font-size: var(--fs-mono);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .project-link-item:hover {
    color: var(--c-text-secondary);
  }

  /* Archive */
  .archive-section {
    margin-top: var(--sp-12);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--c-border);
  }

  .archive-header {
    margin-bottom: var(--sp-5);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-5) var(--sp-6);
  }

  .archive-item {
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--c-border-subtle);
    transition: border-color var(--dur-base) var(--ease-in-out), transform var(--dur-base) var(--ease-out-expo);
  }

  .archive-item:hover {
    border-color: var(--c-border);
    transform: translateY(-2px);
  }

  .archive-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-2);
  }

  .archive-year {
    font-size: 0.7rem;
    color: var(--c-text-faint);
  }

  .archive-link {
    color: var(--c-text-faint);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .archive-link:hover {
    color: var(--c-text-secondary);
  }

  .archive-title {
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: 400;
    line-height: 1.4;
    color: var(--c-text-primary);
    letter-spacing: -0.01em;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .project-entry-inner {
      grid-template-columns: 1fr;
    }

    .project-meta-left {
      flex-direction: row;
      gap: var(--sp-3);
    }

    .arch-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>