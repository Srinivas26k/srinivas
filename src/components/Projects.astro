---
import projects from "../data/projects.json";

type Link = { type: string; label: string; url: string };
type Project = {
  id: string;
  title: string;
  description: string;
  image: string;
  tags: string[];
  links?: Link[];
  year?: number;
  featured?: boolean;
  period?: string;
};

const allProjects = (projects as Project[]);
const sorted = [...allProjects].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return (b.year ?? 0) - (a.year ?? 0);
});

const primary = sorted.filter(p => p.featured);
const archive = sorted.filter(p => !p.featured);

const architectureMap: Record<string, { objective: string; architecture: string; outcome: string }> = {
  "market-trend-agents": {
    objective: "Real-time market intelligence via coordinated agent networks.",
    architecture: "Retriever → Planner → Reasoning agents with shared memory (LangGraph + Google ADK).",
    outcome: "Adaptive trend forecasts from live market data streams."
  },
  "quantum-bb84-sim": {
    objective: "Implement and validate a production-grade quantum key distribution system.",
    architecture: "BB84 protocol → Qiskit simulation → Eavesdrop detection via no-cloning theorem.",
    outcome: "25.1% key generation efficiency. Winner — Qiskit Fall Fest 2025."
  },
  "llm-dataset-suite": {
    objective: "Build scalable fine-tuning corpora for domain-specific LLMs.",
    architecture: "Web scraping → Structured metadata → Prompt-response pairs → Augmentation pipeline.",
    outcome: "4 datasets published. 1,000+ downloads on HuggingFace."
  },
  "annam-ai-rag-scraper": {
    objective: "Automated data pipeline for Retrieval-Augmented Generation systems.",
    architecture: "Recursive crawler → Multi-format extraction → Structured RAG metadata export.",
    outcome: "Base64 ZIP export with PDF text extraction for LLM training pipelines."
  },
  "ayurleaf-healthcare": {
    objective: "Open-source AI health recommendation platform.",
    architecture: "Full-stack bug fixes → UI modules → AI health logic optimization.",
    outcome: "GSSoC 2025 contributions improving analytics dashboard performance."
  },
  "pustak-ghar": {
    objective: "Accessible study resource platform for university students.",
    architecture: "Responsive UI → Branch-wise content filters → Optimized navigation.",
    outcome: "Reduced friction for PYQ access across engineering branches."
  },
};
---

<!-- Ticker band 1 — design.md §9.1 Section 2 -->
<div class="ticker-band" aria-hidden="true">
  <div class="ticker-inner">
    <span class="ticker-text">AI Systems · Quantum Computing · Multi-Agent Architectures · LangChain · Qiskit · Open Source · IIT Madras · Ford · GE Aerospace · DRDO · AI Systems · Quantum Computing · Multi-Agent Architectures · LangChain · Qiskit · Open Source · IIT Madras · Ford · GE Aerospace · DRDO ·&nbsp;</span>
    <span class="ticker-text" aria-hidden="true">AI Systems · Quantum Computing · Multi-Agent Architectures · LangChain · Qiskit · Open Source · IIT Madras · Ford · GE Aerospace · DRDO · AI Systems · Quantum Computing · Multi-Agent Architectures · LangChain · Qiskit · Open Source · IIT Madras · Ford · GE Aerospace · DRDO ·&nbsp;</span>
  </div>
</div>

<section id="work" aria-label="Selected Work">
  <div class="container">

    <!-- Section header — design.md §5 Section Marker Label spec -->
    <div class="work-header reveal">
      <span class="section-marker">Selected Work</span>
      <h2 class="t-display-2 work-title">
        Systems I've<br/>built.
      </h2>
    </div>

    <!-- Primary projects — horizontal list with dividers -->
    <div class="projects-list">
      {primary.map((p, i) => {
        const arch = architectureMap[p.id];
        const year = p.period ?? p.year ?? '';
        const primaryLink = p.links?.[0];
        return (
          <article class="project-entry" data-index={i}>
            <div class="project-entry-inner">

              <!-- Left meta column — index + year -->
              <div class="project-meta-col">
                <span class="t-mono project-index">{String(i + 1).padStart(2, '0')}</span>
                <span class="t-mono project-year">{year}</span>
              </div>

              <!-- Center: Content -->
              <div class="project-content">
                <div class="project-top-row">
                  <h3 class="t-h2 project-title">{p.title}</h3>
                  {primaryLink && (
                    <a
                      href={primaryLink.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-ext-link t-mono"
                      aria-label={`Open ${p.title}`}
                    >
                      ↗
                    </a>
                  )}
                </div>

                <p class="project-description t-body">{p.description}</p>

                <!-- Architecture manifest — design.md system-thinking layer -->
                {arch && (
                  <div class="arch-manifest">
                    <div class="arch-row">
                      <span class="t-label arch-key">Objective</span>
                      <span class="t-mono arch-val">{arch.objective}</span>
                    </div>
                    <div class="arch-row">
                      <span class="t-label arch-key">Architecture</span>
                      <span class="t-mono arch-val">{arch.architecture}</span>
                    </div>
                    <div class="arch-row">
                      <span class="t-label arch-key">Outcome</span>
                      <span class="t-mono arch-val outcome-val">{arch.outcome}</span>
                    </div>
                  </div>
                )}

                <!-- Tags — inline pill design.md §4 -->
                <div class="project-tags">
                  {p.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>

                <!-- External links -->
                {p.links && p.links.length > 0 && (
                  <div class="project-links">
                    {p.links.map(link => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-text project-link-item"
                      >
                        {link.label} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>

            </div>
            <!-- Divider — Line token per design.md -->
            <div class="divider project-divider"></div>
          </article>
        );
      })}
    </div>

    <!-- Archive section -->
    {archive.length > 0 && (
      <div class="archive-section reveal">
        <div class="archive-header">
          <span class="section-marker">Archive</span>
        </div>
        <div class="archive-grid">
          {archive.map((p) => {
            const primaryLink = p.links?.[0];
            return (
              <div class="archive-item">
                <div class="archive-top">
                  <span class="t-mono archive-year">{p.year}</span>
                  {primaryLink && (
                    <a
                      href={primaryLink.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="archive-ext t-mono"
                    >↗</a>
                  )}
                </div>
                <h4 class="t-h3 archive-title">{p.title}</h4>
                <div class="project-tags" style="margin-top: var(--space-3)">
                  {p.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Ghost CTA -->
    <div class="work-cta reveal">
      <a href="https://github.com/Srinivas26k" target="_blank" rel="noopener noreferrer" class="btn-ghost" id="work-view-all-cta">
        View All Projects ↗
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Section Header ─────────────────────────────────────────── */
  .work-header {
    margin-bottom: var(--space-8);
  }

  .work-title {
    margin-top: var(--space-3);
  }

  /* ── Projects List ────────────────────────────────────────────── */
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-entry {
    padding-top: var(--space-5);
  }

  .project-entry-inner {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-6);
    align-items: start;
    padding: var(--space-5);
    border: 1px solid transparent;
    border-radius: var(--radius-card);
    /* No gradient — design.md §8 Don't */
    background: var(--c-ash);
    transition:
      transform var(--dur-medium) var(--ease-out),
      border-color var(--dur-medium) var(--ease-in-out),
      box-shadow var(--dur-medium) var(--ease-out);
  }

  .project-entry:hover .project-entry-inner {
    transform: translateY(-4px);
    border-color: var(--c-line);
    box-shadow: var(--shadow-hover);
  }

  .project-divider {
    margin-top: var(--space-6);
  }

  /* ── Left meta column ────────────────────────────────────────── */
  .project-meta-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 4px;
  }

  .project-index {
    color: var(--c-stone);
    font-size: 12px;
  }

  .project-year {
    color: var(--c-stone);
    font-size: 11px;
  }

  /* ── Content ─────────────────────────────────────────────────── */
  .project-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .project-title {
    max-width: 600px;
  }

  .project-ext-link {
    flex-shrink: 0;
    color: var(--c-stone);
    font-size: 1rem;
    text-decoration: none;
    margin-top: 2px;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .project-ext-link:hover {
    color: var(--c-lime);
  }

  .project-description {
    max-width: 640px;
    margin-bottom: var(--space-5);
    line-height: 1.75;
    color: var(--c-off-white);
    font-weight: 300;
  }

  /* ── Architecture Manifest ───────────────────────────────────── */
  .arch-manifest {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-card);
    background: rgba(240, 238, 233, 0.03);
    margin-bottom: var(--space-5);
    max-width: 640px;
  }

  .arch-row {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .arch-key {
    color: var(--c-stone);
    flex-shrink: 0;
    font-size: 10px;
    letter-spacing: 0.14em;
  }

  .arch-val {
    color: var(--c-stone);
    line-height: 1.5;
  }

  /* Signal Lime for the outcome — one accent per group */
  .outcome-val {
    color: var(--c-off-white);
  }

  /* ── Tags ────────────────────────────────────────────────────── */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  /* ── Project links ─────────────────────────────────────────── */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .project-link-item {
    font-size: 12px;
  }

  /* ── Archive ──────────────────────────────────────────────── */
  .archive-section {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--c-line);
  }

  .archive-header {
    margin-bottom: var(--space-6);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-6) var(--space-7);
  }

  .archive-item {
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--c-line);
    transition: border-color var(--dur-medium) var(--ease-in-out), transform var(--dur-medium) var(--ease-out);
  }

  .archive-item:hover {
    border-color: var(--c-line-strong);
    transform: translateY(-2px);
  }

  .archive-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .archive-year {
    font-size: 11px;
    color: var(--c-stone);
  }

  .archive-ext {
    color: var(--c-stone);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-in-out);
  }

  .archive-ext:hover {
    color: var(--c-lime);
  }

  .archive-title {
    font-size: var(--fs-body-sm);
    font-weight: 400;
    color: var(--c-off-white);
    letter-spacing: -0.01em;
    line-height: 1.4;
  }

  /* ── Work CTA ────────────────────────────────────────────────── */
  .work-cta {
    margin-top: var(--space-8);
    padding-top: var(--space-7);
    border-top: 1px solid var(--c-line);
    display: flex;
    justify-content: center;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .project-entry-inner {
      grid-template-columns: 1fr;
    }

    .project-meta-col {
      flex-direction: row;
      gap: var(--space-4);
    }

    .arch-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .arch-key {
      margin-bottom: 2px;
    }
  }
</style>