---
---
<section id="work" class="selected-works" aria-label="Selected Works">
  <div class="watermark-container">
    <svg class="fit-text watermark" viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid meet">
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" class="watermark-text">
        SELECTED WORKS
      </text>
    </svg>
  </div>

  <div class="container works-grid">
    <!-- Project 1 -->
    <a href="/work/1" class="work-card item-1">
      <div class="work-image-wrap">
        <div class="cover-wipe-work"></div>
        <img src="/images/thumbnail_1.png" alt="Project 1" class="work-image" />
      </div>
      <div class="work-meta">
        <h3 class="t-h2 work-title">Quantum Key Distribution</h3>
        <span class="t-mono work-year">2025</span>
      </div>
    </a>

    <!-- Project 2 -->
    <a href="/work/2" class="work-card item-2">
      <div class="work-image-wrap">
        <div class="cover-wipe-work"></div>
        <img src="/images/thumbnail_2.png" alt="Project 2" class="work-image" />
      </div>
      <div class="work-meta">
        <h3 class="t-h2 work-title">Neobrutalism System</h3>
        <span class="t-mono work-year">2024</span>
      </div>
    </a>

    <!-- Project 3 -->
    <a href="/work/3" class="work-card item-3">
      <div class="work-image-wrap">
        <div class="cover-wipe-work"></div>
        <img src="/images/thumbnail_3.png" alt="Project 3" class="work-image" />
      </div>
      <div class="work-meta">
        <h3 class="t-h2 work-title">Aether Hypercar UI</h3>
        <span class="t-mono work-year">2024</span>
      </div>
    </a>
  </div>
</section>

<style>
  .selected-works {
    position: relative;
    background-color: var(--c-ink);
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
    overflow: hidden;
  }

  .watermark-container {
    width: 100%;
    margin-bottom: var(--space-8);
  }

  .watermark {
    width: 100%;
    height: auto;
    fill: var(--c-stone); 
    opacity: 0.05;
  }

  .watermark-text {
    font-family: var(--font-display);
    font-size: 180px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--space-4);
    align-items: start;
  }

  .work-card {
    display: block;
    position: relative;
    text-decoration: none;
    opacity: 0;
    transform: translateY(40px);
    will-change: transform, opacity;
  }

  .item-1 { grid-column: 1 / 8; margin-top: 0; }
  .item-2 { grid-column: 8 / 13; margin-top: 120px; }
  .item-3 { grid-column: 3 / 10; margin-top: 80px; }

  .work-image-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: var(--space-3);
    cursor: crosshair;
  }

  .cover-wipe-work {
    position: absolute;
    inset: 0;
    background-color: var(--c-ink);
    z-index: 2;
    transform-origin: top;
  }

  .work-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4/5;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }

  .work-card:hover .work-image {
    transform: scale(1.05);
  }

  .work-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    overflow: hidden; /* For slide-up effect */
    padding-top: 8px;
  }

  .work-title {
    color: var(--c-off-white);
    transform: translateY(100%);
    transition: transform 0.4s var(--ease-out);
  }

  .work-year {
    color: var(--c-stone);
    transform: translateY(100%);
    transition: transform 0.4s var(--ease-out) 0.05s;
  }

  .work-card:hover .work-title,
  .work-card:hover .work-year {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .works-grid {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }
    
    .item-1, .item-2, .item-3 {
      margin-top: 0;
    }

    .work-title, .work-year {
      transform: translateY(0);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // 1. Watermark slide-in
    gsap.fromTo(".selected-works .watermark-text", 
      { x: 100, opacity: 0 },
      {
        x: 0, opacity: 1, duration: 1.5, ease: "power3.out",
        scrollTrigger: { trigger: ".selected-works", start: "top 80%" }
      }
    );

    // 2. Card stagger fade-up
    gsap.to(".work-card", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: { trigger: ".works-grid", start: "top 75%" }
    });

    // 3. Cover wipe image reveal
    gsap.utils.toArray(".work-image-wrap").forEach((wrap) => {
      const wipe = (wrap as HTMLElement).querySelector(".cover-wipe-work");
      gsap.to(wipe, {
        scaleY: 0,
        duration: 1.2,
        ease: "expo.inOut",
        scrollTrigger: { trigger: wrap as Element, start: "top 85%" }
      });
    });
  });
</script>