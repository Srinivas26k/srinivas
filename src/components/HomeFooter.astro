---
<!-- Parallax Interlude -->
<section class="parallax-interlude" aria-hidden="true">
  <div class="interlude-bg" style="background-image: url('/images/interlude_bg.png');"></div>
  <div class="interlude-overlay">
    <!-- Circular decorative grid overlay (like VOIR's + grid) -->
    <div class="cross-grid"></div>
  </div>
</section>

<!-- Closing CTA Section -->
<section id="contact" class="closing-cta" aria-label="Contact and Call to Action">
  <div class="cta-bg-wrapper">
    <div class="cta-bg" style="background-image: url('/images/cta_bg.png');"></div>
  </div>
  
  <div class="container cta-content">
    <div class="cards-wrapper">
      <!-- Coloured card behind -->
      <div class="cta-card bg-card"></div>
      
      <!-- White card front -->
      <div class="cta-card fg-card">
        <h2 class="t-display-3 cta-headline">Have a project<br/>in mind?</h2>
        <a href="mailto:srinivasvarma764@gmail.com" class="btn-primary">Let's Talk →</a>
      </div>
    </div>

    <div class="cta-bottom t-label">
      <span>SRINIVAS NAMPALLI STUDIO</span>
      <span>HYDERABAD, INDIA</span>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer-section">
  <div class="container footer-grid">
    <div class="footer-col">
      <h4 class="t-label">NAVIGATION</h4>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/work">Work</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    
    <div class="footer-col">
      <h4 class="t-label">SOCIALS</h4>
      <ul class="footer-links">
        <li><a href="https://in.linkedin.com/in/srinivas-nampalli" target="_blank">LinkedIn</a></li>
        <li><a href="https://github.com/Srinivas26k" target="_blank">GitHub</a></li>
        <li><a href="https://twitter.com" target="_blank">Twitter / X</a></li>
        <li><a href="https://instagram.com" target="_blank">Instagram</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4 class="t-label">CONTACT</h4>
      <ul class="footer-links">
        <li><a href="mailto:srinivasvarma764@gmail.com">srinivasvarma764@gmail.com</a></li>
        <li>+91 123 456 7890</li>
      </ul>
    </div>

    <div class="footer-col footer-portrait-wrap">
      <img src="/images/studio_portrait.png" alt="Portrait" class="footer-portrait" />
    </div>
  </div>

  <div class="footer-huge-text">
    <svg class="fit-text footer-wordmark" viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid meet">
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" class="watermark-text">
        SRINIVAS N.
      </text>
    </svg>
  </div>
</footer>

<style>
  /* Parallax Interlude */
  .parallax-interlude {
    position: relative;
    height: 80vh;
    overflow: hidden;
    background: var(--c-ink);
  }

  .interlude-bg {
    position: absolute;
    inset: -10%;
    background-size: cover;
    background-position: center;
    background-attachment: fixed; /* Simple CSS parallax fallback */
    opacity: 0.6;
    will-change: transform;
  }

  .interlude-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: rgba(17, 17, 17, 0.4); /* Dark wash */
  }

  .cross-grid {
    width: 100%;
    height: 100%;
    background-image: radial-gradient(rgba(249,248,247,0.2) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }

  /* Closing CTA */
  .closing-cta {
    position: relative;
    height: 100vh;
    min-height: 800px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--c-ink);
  }

  .cta-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .cta-bg {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0.4;
    will-change: transform;
  }

  .cta-content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .cards-wrapper {
    position: relative;
    width: 400px;
    height: 400px;
    perspective: 1000px;
  }

  .cta-card {
    position: absolute;
    inset: 0;
    border-radius: 8px;
    box-shadow: var(--shadow-hover);
    will-change: transform;
  }

  .bg-card {
    background: var(--c-taupe);
    transform: rotate(6deg) translateY(20px);
    z-index: 1;
  }

  .fg-card {
    background: var(--c-cream);
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: var(--space-6);
    transform: rotate(-3deg);
  }

  .cta-headline {
    color: var(--c-black);
    margin-bottom: var(--space-5);
  }

  .cta-bottom {
    position: absolute;
    bottom: var(--space-6);
    left: var(--col-pad);
    right: var(--col-pad);
    display: flex;
    justify-content: space-between;
    color: var(--c-off-white);
  }

  /* Footer */
  .footer-section {
    background: var(--c-ink);
    padding-top: var(--space-10);
    overflow: hidden;
    position: relative;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .footer-col h4 {
    color: var(--c-stone);
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-2);
  }

  .footer-links a,
  .footer-links li {
    color: var(--c-off-white);
    text-decoration: none;
    font-size: var(--fs-body);
    transition: color 0.3s ease;
    position: relative;
    display: inline-block;
  }

  .footer-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--c-taupe);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease-out);
  }

  .footer-links a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .footer-portrait-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .footer-portrait {
    width: 120px;
    height: 160px;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .footer-huge-text {
    width: 100%;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .footer-wordmark {
    width: 110%; /* Bleed off edges */
    height: auto;
    fill: var(--c-off-white);
    opacity: 0.9;
    transform: translateY(32px); /* Initial state for animation */
  }

  .footer-wordmark text {
    font-family: var(--font-display);
    font-size: 220px;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  @media (max-width: 768px) {
    .cards-wrapper {
      width: 300px;
      height: 300px;
    }
    
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // 1. Parallax Interlude BG
    gsap.to(".interlude-bg", {
      yPercent: 20,
      ease: "none",
      scrollTrigger: {
        trigger: ".parallax-interlude",
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });

    // 2. CTA Background Parallax
    gsap.to(".cta-bg", {
      yPercent: 15,
      ease: "none",
      scrollTrigger: {
        trigger: ".closing-cta",
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });

    // 3. Angled cards spring entry
    gsap.fromTo(".bg-card", 
      { y: 200, rotation: -9, opacity: 0 },
      { y: 20, rotation: 6, opacity: 1, duration: 1.5, ease: "back.out(1.2)",
        scrollTrigger: { trigger: ".cards-wrapper", start: "top 80%" }
      }
    );

    gsap.fromTo(".fg-card", 
      { y: 250, rotation: -12, opacity: 0 },
      { y: 0, rotation: -3, opacity: 1, duration: 1.5, ease: "back.out(1.2)", delay: 0.1,
        scrollTrigger: { trigger: ".cards-wrapper", start: "top 80%" }
      }
    );

    // 4. Footer Wordmark Reveal
    gsap.to(".footer-wordmark", {
      y: 0,
      duration: 1.5,
      ease: "power3.out",
      scrollTrigger: { trigger: ".footer-section", start: "top 90%" }
    });
  });
</script>