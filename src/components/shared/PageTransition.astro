---
// PageTransition.astro
// Framer Motion-style page transition wrapper
// Ink wash sweep: left → right on exit, right → left on entry
---

<div class="page-transition-wrapper">
  <slot />
</div>

<style>
  .page-transition-wrapper {
    animation: pageEnter 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes pageEnter {
    from {
      opacity: 0;
      clip-path: inset(0 100% 0 0);
    }
    to {
      opacity: 1;
      clip-path: inset(0 0% 0 0);
    }
  }
</style>

<!-- 
  Usage:
  <PageTransition>
    <YourPageContent />
  </PageTransition>

  This component wraps page content and applies a smooth clip-path
  reveal animation inspired by ink wash transitions.
  
  For exit animations, use Astro's view transitions API or add
  a data attribute to trigger inverse animation on route change.
-->
