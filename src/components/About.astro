---
---
<section id="about" aria-label="About Srinivas Nampalli">
  <div class="container">

    <!-- Section header -->
    <div class="about-header reveal">
      <span class="section-marker">About</span>
      <h2 class="t-display-2 about-title">
        More than<br/>a developer.
      </h2>
    </div>

    <!-- Two-column layout — 60/40 per design.md §5 Asymmetric -->
    <div class="about-grid">

      <!-- Left: Bio statement — design.md body-large -->
      <div class="about-bio reveal">
        <p class="t-body-lg about-statement">
          I build systems that think. From quantum key distribution
          protocols to multi-agent AI architectures, my work sits at
          the boundary of <em>engineering discipline</em> and
          <em>computational intelligence</em>.
        </p>
        <p class="t-body about-para">
          Currently pursuing B.S. in Data Science &amp; AI Applications at
          IIT Madras, with a completed Minor in Artificial Intelligence
          from IIT Ropar.
        </p>

        <!-- Metric callouts — design.md §4 Metric/Stat Card style -->
        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-number t-display-3" data-countup="5" data-suffix="+">5+</span>
            <span class="t-label stat-label">Industry<br/>Internships</span>
          </div>
          <div class="stat-item">
            <span class="stat-number t-display-3" data-countup="1000" data-suffix="+">1000+</span>
            <span class="t-label stat-label">HuggingFace<br/>Downloads</span>
          </div>
          <div class="stat-item stat-item--lime">
            <span class="stat-number t-display-3 stat-lime" data-countup="1" data-suffix="×">1×</span>
            <span class="t-label stat-label">Qiskit Fall<br/>Fest Winner</span>
          </div>
        </div>
      </div>

      <!-- Right: System Manifest — Ash card per design.md §4 -->
      <div class="about-manifest surface-card reveal">

        <!-- Experience list -->
        <div class="manifest-block">
          <span class="t-label manifest-heading">Experience</span>
          <ul class="manifest-list">
            <li class="manifest-item">
              <span class="t-mono item-role">Project Intern</span>
              <span class="t-mono item-org">Ford Motor Company (EV Engineering)</span>
              <span class="t-mono item-period">Apr – May 2024</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Aerospace Engineering Intern</span>
              <span class="t-mono item-org">GE Aerospace</span>
              <span class="t-mono item-period">Oct – Nov 2023</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Defense Technology Intern</span>
              <span class="t-mono item-org">DRDO (DRDL)</span>
              <span class="t-mono item-period">Jun – Nov 2022</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Executive Assistant</span>
              <span class="t-mono item-org">Lab of Education Design, IIT Ropar</span>
              <span class="t-mono item-period">Mar – May 2025</span>
            </li>
            <li class="manifest-item manifest-item--last">
              <span class="t-mono item-role">Freelance Consultant</span>
              <span class="t-mono item-org">Self-Employed</span>
              <span class="t-mono item-period">Jan 2024 – Present</span>
            </li>
          </ul>
        </div>

        <div class="manifest-divider divider"></div>

        <!-- Stack -->
        <div class="manifest-block">
          <span class="t-label manifest-heading">Stack</span>
          <div class="stack-grid">
            <div class="stack-group">
              <span class="t-label stack-category">AI / ML</span>
              <span class="t-mono stack-items">LangChain · LangGraph · Google ADK · Qiskit · TensorFlow</span>
            </div>
            <div class="stack-group">
              <span class="t-label stack-category">Systems</span>
              <span class="t-mono stack-items">Python · FastAPI · Streamlit · Zoom OAuth · Whisper</span>
            </div>
            <div class="stack-group">
              <span class="t-label stack-category">Engineering</span>
              <span class="t-mono stack-items">CAD/CAM · FEA · Thermal Analysis · CNC Manufacturing</span>
            </div>
            <div class="stack-group">
              <span class="t-label stack-category">Web</span>
              <span class="t-mono stack-items">Astro · React · TypeScript</span>
            </div>
          </div>
        </div>

        <div class="manifest-divider divider"></div>

        <!-- Recognition — Signal Lime dots -->
        <div class="manifest-block">
          <span class="t-label manifest-heading">Recognition</span>
          <ul class="recognition-list">
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              Winner — IIIT Hyderabad × IBM Qiskit Fall Fest 2025
            </li>
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              Top 8.2% — GirlScript Summer of Code 2025 (Rank #245)
            </li>
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              1,000+ Downloads — 4 AI Datasets on HuggingFace
            </li>
          </ul>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  /* ── Header ─────────────────────────────────────────────────── */
  .about-header {
    margin-bottom: var(--space-8);
  }

  .about-title {
    margin-top: var(--space-3);
  }

  /* ── 60/40 Grid ──────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  @media (max-width: 1023px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  /* ── Bio ─────────────────────────────────────────────────────── */
  .about-statement {
    max-width: 520px;
    margin-bottom: var(--space-5);
  }

  .about-statement em {
    font-style: normal;
    color: var(--c-white);
  }

  .about-para {
    color: var(--c-stone);
    max-width: 460px;
    margin-bottom: var(--space-7);
  }

  /* ── Stats Row — metric callouts ─────────────────────────────── */
  .stats-row {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .stat-number {
    font-variant-numeric: tabular-nums;
    color: var(--c-white);
  }

  /* Signal Lime for the hero stat — one per group per design.md */
  .stat-lime {
    color: var(--c-lime);
  }

  .stat-label {
    color: var(--c-stone);
    line-height: 1.4;
  }

  /* ── Manifest Card ───────────────────────────────────────────── */
  .about-manifest {
    padding: clamp(20px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .manifest-divider {
    opacity: 1;
  }

  .manifest-block {}

  .manifest-heading {
    display: block;
    margin-bottom: var(--space-3);
    color: var(--c-stone);
  }

  /* Experience list */
  .manifest-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .manifest-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-3);
    align-items: baseline;
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--c-line);
  }

  .manifest-item--last {
    border-bottom: none;
    padding-bottom: 0;
  }

  .item-role {
    color: var(--c-off-white);
    font-size: var(--fs-mono);
    white-space: nowrap;
  }

  .item-org {
    color: var(--c-stone);
    font-size: var(--fs-mono);
    text-align: center;
  }

  .item-period {
    color: var(--c-stone);
    font-size: 11px;
    white-space: nowrap;
    text-align: right;
  }

  /* Stack */
  .stack-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stack-group {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .stack-category {
    color: var(--c-stone);
    font-size: 10px;
    letter-spacing: 0.14em;
  }

  .stack-items {
    color: var(--c-off-white);
    font-size: var(--fs-mono);
    line-height: 1.5;
  }

  /* Recognition */
  .recognition-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .recognition-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--c-off-white);
    font-size: var(--fs-mono);
    line-height: 1.5;
  }

  .rec-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--c-lime);
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .manifest-item {
      grid-template-columns: 1fr;
      gap: 3px;
    }
    .item-period { text-align: left; }
    .item-org { text-align: left; }

    .stack-group {
      grid-template-columns: 1fr;
      gap: 3px;
    }

    .stats-row {
      gap: var(--space-5);
    }
  }
</style>
