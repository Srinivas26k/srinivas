---
---
<section id="about" aria-label="About Srinivas Nampalli">
  <div class="container">

    <!-- Section header -->
    <div class="section-header reveal">
      <span class="t-label">About</span>
      <div class="divider" style="margin-top: var(--sp-3)"></div>
    </div>

    <!-- Two-column layout -->
    <div class="about-grid">

      <!-- Left: Bio -->
      <div class="about-bio reveal">
        <p class="about-statement">
          I build systems that think. From quantum key distribution
          protocols to multi-agent AI architectures, my work sits at
          the boundary of <em>engineering discipline</em> and
          <em>computational intelligence</em>.
        </p>
        <p class="t-small" style="margin-top: var(--sp-4)">
          Currently pursuing B.S. in Data Science & AI Applications at
          IIT Madras, with a completed Minor in Artificial Intelligence
          from IIT Ropar.
        </p>
      </div>

      <!-- Right: System Manifest (capabilities) -->
      <div class="about-manifest reveal">
        <div class="manifest-block">
          <span class="t-label manifest-heading">Experience</span>
          <ul class="manifest-list">
            <li class="manifest-item">
              <span class="t-mono item-role">Project Intern</span>
              <span class="t-mono item-org">Ford Motor Company (EV Engineering)</span>
              <span class="t-mono item-period">Apr – May 2024</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Aerospace Engineering Intern</span>
              <span class="t-mono item-org">GE Aerospace</span>
              <span class="t-mono item-period">Oct – Nov 2023</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Defense Technology Intern</span>
              <span class="t-mono item-org">DRDO (DRDL)</span>
              <span class="t-mono item-period">Jun – Nov 2022</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Executive Assistant</span>
              <span class="t-mono item-org">Lab of Education Design, IIT Ropar</span>
              <span class="t-mono item-period">Mar – May 2025</span>
            </li>
            <li class="manifest-item">
              <span class="t-mono item-role">Freelance Consultant</span>
              <span class="t-mono item-org">Self-Employed</span>
              <span class="t-mono item-period">Jan 2024 – Present</span>
            </li>
          </ul>
        </div>

        <div class="manifest-block" style="margin-top: var(--sp-6)">
          <span class="t-label manifest-heading">Stack</span>
          <div class="stack-grid">
            <div class="stack-group">
              <span class="t-mono stack-category">AI / ML</span>
              <span class="t-mono stack-items">LangChain · LangGraph · Google ADK · Qiskit · TensorFlow</span>
            </div>
            <div class="stack-group">
              <span class="t-mono stack-category">Systems</span>
              <span class="t-mono stack-items">Python · FastAPI · Streamlit · Zoom OAuth · Whisper</span>
            </div>
            <div class="stack-group">
              <span class="t-mono stack-category">Engineering</span>
              <span class="t-mono stack-items">CAD/CAM · FEA · Thermal Analysis · CNC Manufacturing</span>
            </div>
            <div class="stack-group">
              <span class="t-mono stack-category">Web</span>
              <span class="t-mono stack-items">Astro · React · Tailwind · TypeScript</span>
            </div>
          </div>
        </div>

        <div class="manifest-block" style="margin-top: var(--sp-6)">
          <span class="t-label manifest-heading">Recognition</span>
          <ul class="recognition-list">
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              Winner — IIIT Hyderabad × IBM Qiskit Fall Fest 2025
            </li>
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              Top 8.2% — GirlScript Summer of Code 2025 (Rank #245)
            </li>
            <li class="t-mono recognition-item">
              <span class="rec-dot" aria-hidden="true"></span>
              1,000+ Downloads — 4 AI Datasets on HuggingFace
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--sp-8);
  }

  /* About grid */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-8);
    }
  }

  /* Bio */
  .about-statement {
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.65;
    color: var(--c-text-secondary);
    letter-spacing: -0.01em;
  }

  .about-statement em {
    font-style: normal;
    color: var(--c-text-primary);
  }

  /* Manifest */
  .manifest-block {}

  .manifest-heading {
    display: block;
    margin-bottom: var(--sp-3);
    color: var(--c-text-faint);
  }

  /* Experience list */
  .manifest-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .manifest-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--sp-2);
    align-items: baseline;
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-border-subtle);
  }

  .manifest-item:last-child {
    border-bottom: none;
  }

  .item-role {
    color: var(--c-text-secondary);
    font-size: var(--fs-mono);
    white-space: nowrap;
  }

  .item-org {
    color: var(--c-text-faint);
    font-size: var(--fs-mono);
    text-align: center;
  }

  .item-period {
    color: var(--c-text-faint);
    font-size: 0.7rem;
    white-space: nowrap;
    text-align: right;
  }

  /* Stack */
  .stack-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .stack-group {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--sp-2);
    align-items: baseline;
  }

  .stack-category {
    color: var(--c-text-faint);
    font-size: 0.7rem;
  }

  .stack-items {
    color: var(--c-text-secondary);
    font-size: var(--fs-mono);
    line-height: 1.5;
  }

  /* Recognition */
  .recognition-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .recognition-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--c-text-secondary);
    font-size: var(--fs-mono);
  }

  .rec-dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--c-text-faint);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .manifest-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .item-period { text-align: left; }
    .item-org { text-align: left; }
  }
</style>
