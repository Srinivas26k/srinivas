---
---
<section id="about" class="studio-intro" aria-label="About the Studio">
  <div class="watermark-container">
    <svg class="fit-text watermark" viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid meet">
      <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" class="watermark-text">
        INSIDE SRINIVAS
      </text>
    </svg>
  </div>

  <div class="container intro-grid">
    <div class="intro-content">
      <h2 class="t-display-3 intro-headline">
        <span class="word-blur">We</span> <span class="word-blur">are</span> <span class="word-blur">a</span> <span class="word-blur">design</span> <span class="word-blur">studio</span> <br/>
        <span class="word-blur">focused</span> <span class="word-blur">on</span> <span class="word-blur">creating</span> <br/>
        <span class="word-blur">intelligent</span> <span class="word-blur">systems.</span>
      </h2>
      
      <div class="metrics-row">
        <div class="metric">
          <div class="t-display-2 metric-number" data-target="5">0</div>
          <div class="t-label metric-label">Years Creating</div>
        </div>
        <div class="metric">
          <div class="t-display-2 metric-number" data-target="42">0</div>
          <div class="t-label metric-label">Projects Delivered</div>
        </div>
        <div class="metric">
          <div class="t-display-2 metric-number" data-target="15">0</div>
          <div class="t-label metric-label">Clients Worldwide</div>
        </div>
      </div>

      <a href="/about" class="btn-text">About Us →</a>
    </div>

    <div class="intro-image-wrap">
      <div class="cover-wipe"></div>
      <img src="/images/studio_portrait.png" alt="Studio Portrait" class="intro-image" />
    </div>
  </div>
</section>

<style>
  .studio-intro {
    position: relative;
    background-color: var(--c-ash);
    color: var(--c-black);
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
    overflow: hidden;
  }

  .watermark-container {
    width: 100%;
    margin-bottom: var(--space-8);
  }

  .watermark {
    width: 100%;
    height: auto;
    fill: var(--c-bone); 
    opacity: 0.15;
  }

  .watermark-text {
    font-family: var(--font-display);
    font-size: 180px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  .intro-headline {
    color: var(--c-black);
    margin-bottom: var(--space-8);
  }

  .intro-headline .word-blur {
    display: inline-block;
    filter: blur(10px);
    opacity: 0;
    transform: translateY(20px);
    will-change: filter, transform, opacity;
  }

  .metrics-row {
    display: flex;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .metric-number {
    color: var(--c-black);
    margin-bottom: var(--space-2);
  }

  .metric-label {
    color: rgba(17, 17, 17, 0.64);
  }

  .btn-text {
    color: var(--c-black);
  }
  
  .btn-text::after {
    background: var(--c-black);
  }

  .intro-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .cover-wipe {
    position: absolute;
    inset: 0;
    background-color: var(--c-ash);
    z-index: 2;
    transform-origin: top;
  }

  .intro-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.2);
  }

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo(".watermark-text", 
      { x: -100, opacity: 0 },
      {
        x: 0, opacity: 1, duration: 1.5, ease: "power3.out",
        scrollTrigger: { trigger: ".studio-intro", start: "top 80%" }
      }
    );

    gsap.to(".word-blur", {
      filter: "blur(0px)",
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.05,
      ease: "power2.out",
      scrollTrigger: { trigger: ".intro-headline", start: "top 85%" }
    });

    const metrics = document.querySelectorAll(".metric-number");
    metrics.forEach(metric => {
      const target = parseInt(metric.getAttribute("data-target") || "0", 10);
      gsap.to(metric, {
        innerHTML: target,
        duration: 2,
        snap: { innerHTML: 1 },
        ease: "power1.inOut",
        scrollTrigger: { trigger: ".metrics-row", start: "top 85%" },
        onUpdate: function() {
          metric.innerHTML = Math.ceil(this.targets()[0].innerHTML) + "+";
        }
      });
    });

    gsap.to(".cover-wipe", {
      scaleY: 0,
      duration: 1.2,
      ease: "expo.inOut",
      scrollTrigger: { trigger: ".intro-image-wrap", start: "top 75%" }
    });
  });
</script>
