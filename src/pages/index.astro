import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Main from "../components/Main.astro";
import HomeIntro from "../components/HomeIntro.astro";
import HomeWorks from "../components/HomeWorks.astro";
import HomeTestimonials from "../components/HomeTestimonials.astro";
import HomeServices from "../components/HomeServices.astro";
import HomeCraft from "../components/HomeCraft.astro";
